# ─── API ───────────────────────────────────────────────────────────────────────
# Full URL of the REST API (no trailing slash)
VITE_API_BASE_URL=http://localhost:4000/api/v1

# ─── WebSocket ─────────────────────────────────────────────────────────────────
# Origin for Socket.IO connection (matches backend CORS_ORIGIN)
VITE_WS_BASE_URL=http://localhost:4000

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Stripe publishable key (safe to expose in frontend)
VITE_STRIPE_PUBLIC_KEY=pk_test_replace_me

# ─── Web Push / PWA ────────────────────────────────────────────────────────────
# VAPID public key — generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=replace_me_vapid_public_key
