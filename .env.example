# ─── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Auth ──────────────────────────────────────────────────────────────────────
# CHANGE THESE IN PRODUCTION — use `openssl rand -hex 64` to generate
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quiz_royale?schema=public

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── pgAdmin (local dev only) ──────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@quizroyale.local
PGADMIN_DEFAULT_PASSWORD=admin

# ─── Web App ───────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_WS_BASE_URL=http://localhost:4000
VITE_STRIPE_PUBLIC_KEY=pk_test_replace_me
VITE_VAPID_PUBLIC_KEY=replace_me_vapid_public_key

# ─── Cloud (production) ────────────────────────────────────────────────────────
# RAILWAY_TOKEN=
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_CLOUDFRONT_DOMAIN=
