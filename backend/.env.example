# ─── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGIN=http://localhost:5173

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── Database ──────────────────────────────────────────────────────────────────
# Full Prisma connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quiz_royale?schema=public

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=info   # trace | debug | info | warn | error | fatal

# ─── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:adapluguez@gmail.com

# ─── Admin ─────────────────────────────────────────────────────────────────────
# ADMIN_API_KEY=change-me-admin-key
