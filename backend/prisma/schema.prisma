generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum RoomStatus {
  WAITING
  COUNTDOWN
  QUESTION_ACTIVE
  ANSWER_LOCKED
  ROUND_RESULT
  ELIMINATION
  FINALE
  GAME_OVER
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum CosmeticType {
  AVATAR
  FRAME
  TITLE
}

model User {
  id               String            @id @db.VarChar(26)
  email            String            @unique
  displayName      String
  passwordHash     String
  avatarUrl        String?
  rating           Int               @default(1000)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  refreshTokens          RefreshToken[]
  roomsHosted            Room[]            @relation("HostedRooms")
  roomPlayers            RoomPlayer[]
  answers                Answer[]
  playerPowerUps         PlayerPowerUp[]
  powerUpUses            PowerUpUse[]
  userCosmetics          UserCosmetic[]
  xpEvents               XpEvent[]
  seasonScores           SeasonScore[]
  purchaseReceipts       PurchaseReceipt[]
  sentFriendRequests     Friendship[]      @relation("FriendshipRequester")
  receivedFriendRequests Friendship[]      @relation("FriendshipAddressee")
  pushSubscriptions      PushSubscription[]

  @@index([displayName])
}

model RefreshToken {
  id        String   @id @db.VarChar(26)
  userId    String   @db.VarChar(26)
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
}

model Room {
  id             String       @id @db.VarChar(26)
  code           String       @unique @db.VarChar(8)
  hostUserId     String       @db.VarChar(26)
  seasonId       String?      @db.VarChar(26)
  status         RoomStatus   @default(WAITING)
  currentRound   Int          @default(0)
  totalRounds    Int          @default(10)
  createdAt      DateTime     @default(now())
  startedAt      DateTime?
  finishedAt     DateTime?
  inviteCode     String?      @unique
  host           User         @relation("HostedRooms", fields: [hostUserId], references: [id])
  rounds         Round[]
  players        RoomPlayer[]
  season         Season?      @relation(fields: [seasonId], references: [id])
}

model RoomPlayer {
  id             String   @id @db.VarChar(26)
  roomId         String   @db.VarChar(26)
  userId         String   @db.VarChar(26)
  seatIndex      Int
  score          Int      @default(0)
  streak         Int      @default(0)
  isEliminated   Boolean  @default(false)
  eliminatedAt   DateTime?
  joinedAt       DateTime @default(now())
  room           Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model Round {
  id             String       @id @db.VarChar(26)
  roomId         String       @db.VarChar(26)
  roundNumber    Int
  questionId     String       @db.VarChar(26)
  difficulty     Difficulty
  startedAt      DateTime?
  lockedAt       DateTime?
  resolvedAt     DateTime?
  room           Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  question       QuestionBank @relation(fields: [questionId], references: [id])
  answers        Answer[]

  @@unique([roomId, roundNumber])
}

model Answer {
  id            String   @id @db.VarChar(26)
  roundId       String   @db.VarChar(26)
  userId        String   @db.VarChar(26)
  answerIndex   Int
  isCorrect     Boolean
  answerTimeMs  Int
  submittedAt   DateTime @default(now())
  round         Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roundId, userId])
}

model QuestionBank {
  id               String       @id @db.VarChar(26)
  prompt           String
  optionA          String
  optionB          String
  optionC          String
  optionD          String
  correctIndex     Int
  category         String
  difficulty       Difficulty
  lastUsedAt       DateTime?
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  rounds           Round[]

  @@index([isActive, lastUsedAt])
}

model PowerUp {
  id             String         @id @db.VarChar(26)
  code           String         @unique
  name           String
  description    String
  rarity         String
  cooldownSecs   Int
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  playerPowerUps PlayerPowerUp[]
  uses           PowerUpUse[]
}

model PlayerPowerUp {
  id          String   @id @db.VarChar(26)
  userId      String   @db.VarChar(26)
  powerUpId   String   @db.VarChar(26)
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  powerUp     PowerUp  @relation(fields: [powerUpId], references: [id], onDelete: Cascade)

  @@unique([userId, powerUpId])
}

model PowerUpUse {
  id             String   @id @db.VarChar(26)
  roomId         String   @db.VarChar(26)
  roundId        String?  @db.VarChar(26)
  userId         String   @db.VarChar(26)
  powerUpId      String   @db.VarChar(26)
  targetPlayerId String?  @db.VarChar(26)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  powerUp        PowerUp  @relation(fields: [powerUpId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roomId])
}

model Cosmetic {
  id            String         @id @db.VarChar(26)
  code          String         @unique
  type          CosmeticType
  name          String
  assetUrl      String
  rarity        String
  createdAt     DateTime       @default(now())
  userCosmetics UserCosmetic[]
}

model UserCosmetic {
  id           String   @id @db.VarChar(26)
  userId       String   @db.VarChar(26)
  cosmeticId   String   @db.VarChar(26)
  equipped     Boolean  @default(false)
  acquiredAt   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cosmetic     Cosmetic @relation(fields: [cosmeticId], references: [id], onDelete: Cascade)

  @@unique([userId, cosmeticId])
}

model XpEvent {
  id          String   @id @db.VarChar(26)
  userId      String   @db.VarChar(26)
  reason      String
  amount      Int
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Season {
  id            String        @id @db.VarChar(26)
  slug          String        @unique
  name          String
  startsAt      DateTime
  endsAt        DateTime
  createdAt     DateTime      @default(now())
  rooms         Room[]
  seasonScores  SeasonScore[]
}

model SeasonScore {
  id            String   @id @db.VarChar(26)
  seasonId      String   @db.VarChar(26)
  userId        String   @db.VarChar(26)
  mmr           Int      @default(1000)
  wins          Int      @default(0)
  gamesPlayed   Int      @default(0)
  updatedAt     DateTime @updatedAt
  season        Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
  @@index([userId])
}

model PurchaseReceipt {
  id                String   @id @db.VarChar(26)
  userId            String   @db.VarChar(26)
  provider          String
  providerReceiptId String   @unique
  sku               String
  amountCents       Int
  currencyCode      String   @db.VarChar(3)
  status            String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @db.VarChar(26)
  userId    String   @db.VarChar(26)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Friendship {
  id          String           @id @db.VarChar(26)
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id])
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
}
